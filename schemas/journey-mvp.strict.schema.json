{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://josephurben.github.io/less-visited-journey/schemas/journey-mvp.strict.schema.json",
  "title": "Less Visited MVP Journey",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "journeyId",
    "publicTripId",
    "productType",
    "demo",
    "journeyStatus",
    "journeyVersion",
    "travellerName",
    "destination",
    "tripTitle",
    "subtitle",
    "startDate",
    "endDate",
    "timezone",
    "currency",
    "intro",
    "routeOverview",
    "accommodation",
    "bookings",
    "preparationChecklist",
    "packingChecklist",
    "budget",
    "map",
    "practicalInfo",
    "emergencyInfo",
    "days",
    "places"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 2 },
    "journeyId": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "publicTripId": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "productType": { "type": "string" },
    "demo": { "type": "boolean" },
    "journeyStatus": { "type": "string", "enum": ["awaiting_approval", "approved"] },
    "journeyVersion": { "type": "integer", "minimum": 1 },
    "travellerName": { "type": "string" },
    "destination": { "type": "string" },
    "tripTitle": { "type": "string" },
    "subtitle": { "type": "string" },
    "startDate": { "type": "string", "format": "date" },
    "endDate": { "type": "string", "format": "date" },
    "timezone": { "type": "string" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "intro": { "type": "string" },
    "routeOverview": { "type": "string" },
    "accommodation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "guidance"],
      "properties": {
        "base": { "type": "string" },
        "guidance": { "type": "string" }
      }
    },
    "bookings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "reference", "note"],
        "properties": {
          "label": { "type": "string" },
          "reference": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "preparationChecklist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "label": { "type": "string" }
        }
      }
    },
    "packingChecklist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
          "label": { "type": "string" }
        }
      }
    },
    "budget": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "amount"],
        "properties": {
          "label": { "type": "string" },
          "amount": { "type": ["number", "null"] }
        }
      }
    },
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url"],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "practicalInfo": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "emergencyInfo": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" }
        }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/day" }
    },
    "places": {
      "type": "array",
      "items": { "$ref": "#/$defs/place" }
    }
  },
  "$defs": {
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "date", "location", "theme", "summary", "routeLogic", "activities"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "date": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "theme": { "type": "string" },
        "summary": { "type": "string" },
        "routeLogic": { "type": "string" },
        "activities": {
          "type": "array",
          "items": { "$ref": "#/$defs/activity" }
        }
      }
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "placeId", "time", "title", "category", "type", "description", "duration", "travelTime", "cost", "address", "latitude", "longitude", "practicalNote", "alternative", "verification"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "placeId": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9_-]+$" },
        "time": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["fixed", "suggested", "optional", "food", "task"] },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "travelTime": { "type": "string" },
        "cost": { "type": "string" },
        "address": { "type": "string" },
        "latitude": { "type": ["number", "null"] },
        "longitude": { "type": ["number", "null"] },
        "practicalNote": { "type": "string" },
        "alternative": { "type": "string" },
        "verification": { "type": "string" }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "destination", "neighbourhood", "category", "description", "address", "mapUrl", "latitude", "longitude", "practicalNote", "tags", "scheduled", "active", "alternativeFor", "bestFor"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
        "name": { "type": "string" },
        "destination": { "type": "string" },
        "neighbourhood": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "address": { "type": "string" },
        "mapUrl": { "type": "string" },
        "latitude": { "type": ["number", "null"] },
        "longitude": { "type": ["number", "null"] },
        "practicalNote": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "scheduled": { "type": "boolean" },
        "active": { "type": "boolean" },
        "alternativeFor": { "type": "string" },
        "bestFor": { "type": "string" }
      }
    }
  }
}
